<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->
        
        <bean id="hello" class="com.bg.beans.HelloWorld" scope="prototype">
     <!--    <property name="name" value="swati"></property> --> 
        <constructor-arg name="name" value="Raghav"></constructor-arg>
        <property name="language" >
        <list>
        <value>English</value>
        <value>Hindi</value>
        <value>French</value>
        </list>
        </property>  
        </bean>
        
        
        <bean id="employee" class="com.bg.beans.Employee">
        <property name="empid" value="100"></property>
        <property name="name" value="amit"></property>
        <property name="address" ref="add"></property>
        </bean>
        
         <bean id="add" class="com.bg.beans.Address">
        <property name="city" value="Noida"></property>
        <property name="country" value="India"></property>
        <property name="zip" value="201310"></property>
        </bean>
</beans>